{
  "name": "@andrezzoid/strata",
  "version": "0.1.0",
  "description": "Deterministic candidate scanner for PoSD-style complexity red flags in TypeScript codebases.",
  "license": "MIT",
  "homepage": "https://github.com/andrezzoid/strata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrezzoid/strata.git"
  },
  "bugs": {
    "url": "https://github.com/andrezzoid/strata/issues"
  },
  "keywords": [
    "complexity",
    "posd",
    "scanner",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "strata": "./bin/strata.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "scan": "bun src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "oxc-parser": "^0.129.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
